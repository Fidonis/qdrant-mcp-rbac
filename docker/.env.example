# Environment for docker/docker-compose.yml.
# Copy this file to docker/.env and fill in real values.
# docker/.env is gitignored and MUST NOT be committed.

# --- OIDC / Keycloak ---
# This compose does NOT run Keycloak. Point this at an external OIDC provider
# (a Keycloak realm URL) that is reachable from inside the container.
OIDC_ISSUER_URL=https://keycloak.example.com/realms/myrealm
# Audience claim that must be present in the access token.
OIDC_AUDIENCE=mcp-server
# JWKS cache TTL in seconds.
OIDC_JWKS_CACHE_TTL=3600

# --- Qdrant ---
# In-container address of the `qdrant` service defined in docker-compose.yml.
QDRANT_URL=http://qdrant:6333
# Signing secret for Qdrant JWTs. Used by BOTH the mcp-server and the qdrant
# service (as QDRANT__SERVICE__API_KEY) - the two values MUST be identical.
QDRANT_JWT_SECRET=change-me-to-a-strong-secret
# TTL of derived Qdrant JWTs in seconds.
QDRANT_JWT_TTL=3600

# --- MCP server ---
# The container always listens on 0.0.0.0:8000. To publish on a different host
# port, edit the `ports:` mapping in docker-compose.yml rather than MCP_PORT.
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp

# --- Logging ---
LOG_LEVEL=INFO

# --- Embeddings ---
# OpenAI-compatible embeddings endpoint. To reach a provider running on the
# Docker host, use host.docker.internal instead of localhost.
EMBEDDING_API_URL=http://host.docker.internal:11434/v1
# API key for the embeddings endpoint. Leave empty for unauthenticated providers.
EMBEDDING_API_KEY=
# Qdrant collection holding the per-collection embedding model metadata.
EMBEDDING_META_COLLECTION=_collection_meta

# --- RBAC ---
# Break-glass admin role: members always receive a global Qdrant manage token.
RBAC_ADMIN_ROLE=qdrant-admin
# Qdrant collection holding role-grants. Auto-created on first access.
RBAC_ACL_COLLECTION=_rbac_acl
# In-memory ACL cache TTL in seconds.
RBAC_ACL_CACHE_TTL=60
# TTL for the service token used by the server to read the ACL collection.
RBAC_SERVICE_TOKEN_TTL=60
