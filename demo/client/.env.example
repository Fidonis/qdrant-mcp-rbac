# --- OIDC / Keycloak ---
# Realm issuer URL (same value the MCP server uses)
OIDC_ISSUER_URL=https://auth.papaia.die-boehms.online/realms/papaia
# Confidential or public client registered in Keycloak
OIDC_CLIENT_ID=mcp-qdrant
# Leave empty for a public client (no secret)
OIDC_CLIENT_SECRET=your-client-secret-here
# Grant type: "password" (Resource Owner Password Credentials) or
# "client_credentials" (service-account flow). Default: password
OIDC_GRANT_TYPE=client_credentials
# For password grant only:
OIDC_USERNAME=alice
OIDC_PASSWORD=alice-password
# Optional extra scopes (space-separated). "openid" is added automatically.
OIDC_SCOPES=

# --- MCP server ---
# Streamable-HTTP endpoint of the qdrant-mcp-rbac server (matches MCP_PATH there)
MCP_SERVER_URL=http://localhost:8000/mcp

# --- LLM (litellm) ---
# Any litellm model id, e.g.:
#   gpt-4o-mini             (set OPENAI_API_KEY)
#   anthropic/claude-3-5-sonnet-latest  (set ANTHROPIC_API_KEY)
#   ollama/llama3.1         (set LLM_API_BASE=http://localhost:11434)
#   azure/<deployment>      (set AZURE_API_KEY, AZURE_API_BASE, AZURE_API_VERSION)
LLM_MODEL=openai/deepinfra/gpt-oss-120b
# Optional override for OpenAI-compatible endpoints (Ollama, vLLM, LM Studio, ...)
LLM_API_BASE=http://server:8200/v1
# Optional API key passed straight to litellm (otherwise the provider's default
# env var is used: OPENAI_API_KEY, ANTHROPIC_API_KEY, ...)
LLM_API_KEY=your-llm-api-key-here
# Sampling temperature
LLM_TEMPERATURE=0.2
# Maximum agent iterations (LLM <-> tool round-trips) per user turn
LLM_MAX_ITERATIONS=8
# Optional system prompt override
LLM_SYSTEM_PROMPT=

# --- Logging ---
LOG_LEVEL=INFO
