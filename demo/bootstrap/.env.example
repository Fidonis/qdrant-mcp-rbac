# --- Qdrant ---
# Qdrant HTTP endpoint
QDRANT_URL=http://localhost:6333
# Optional API key / JWT for Qdrant (leave empty for unauthenticated local Qdrant)
QDRANT_API_KEY=change-me-to-a-strong-secret

# --- Embeddings ---
# OpenAI-compatible embeddings base URL. Must include the API prefix (e.g.
# /v1 for OpenAI, vLLM, Ollama, LocalAI, ...).
EMBEDDING_API_URL=http://localhost:11434/v1
# Optional bearer token for the embeddings endpoint. Leave empty for
# unauthenticated local providers.
EMBEDDING_API_KEY=
# Model name passed to the endpoint. For non-English data use e.g.
# paraphrase-multilingual-MiniLM-L12-v2 (or whatever the provider serves).
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Qdrant collection that records which model produced each collection's
# vectors. Read by the MCP server at query time.
EMBEDDING_META_COLLECTION=_collection_meta
# Texts per /embeddings request
EMBEDDING_BATCH=32

# --- Source data ---
# Directory containing the *.md files (one per role). Defaults to ./data
# next to vectorize.py if unset.
DATA_DIR=../data

# --- Chunking ---
# Approximate tokens per chunk (whitespace-tokenized)
CHUNK_TOKENS=500
# Token overlap between adjacent chunks
CHUNK_OVERLAP=50

# --- Logging ---
LOG_LEVEL=INFO
