# --- OIDC / Keycloak ---
# Issuer URL of your OIDC provider (Keycloak realm URL)
OIDC_ISSUER_URL=https://keycloak.example.com/realms/myrealm
# Audience claim that must be present in the access token
OIDC_AUDIENCE=mcp-server
# JWKS cache TTL in seconds
OIDC_JWKS_CACHE_TTL=3600

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
# Signing secret for Qdrant JWTs (must match Qdrant's `service.api_key`)
QDRANT_JWT_SECRET=change-me-to-a-strong-secret
# TTL of derived Qdrant JWTs in seconds
QDRANT_JWT_TTL=3600

# --- MCP server ---
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp

# --- Logging ---
LOG_LEVEL=INFO

# --- Embeddings ---
# OpenAI-compatible embeddings endpoint. The base URL must already include
# the API prefix (e.g. /v1 for OpenAI, vLLM, Ollama, LocalAI, ...).
EMBEDDING_API_URL=http://localhost:11434/v1
# API key for the embeddings endpoint. Leave empty for unauthenticated local
# providers (e.g. a default Ollama install).
EMBEDDING_API_KEY=
# Qdrant collection holding the per-collection embedding model metadata.
# Populated by bootstrap at ingestion time. Auto-bootstrapped if missing.
EMBEDDING_META_COLLECTION=_collection_meta

# --- RBAC ---
# Break-glass admin role: members of this OIDC role always receive a global
# Qdrant manage token (used to bootstrap and edit the ACL collection).
RBAC_ADMIN_ROLE=qdrant-admin
# Qdrant collection holding role-grants. Auto-created on first access.
RBAC_ACL_COLLECTION=_rbac_acl
# In-memory ACL cache TTL in seconds. Admin mutations invalidate the cache
# immediately; this only affects out-of-band changes to the ACL collection.
RBAC_ACL_CACHE_TTL=60
# TTL for the service token used by the server to read the ACL collection.
RBAC_SERVICE_TOKEN_TTL=60
